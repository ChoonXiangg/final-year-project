# Sepolia deployment credentials
SEPOLIA_RPC_URL=
PRIVATE_KEY=

# Etherscan API key for verifying contracts after deployment (optional)
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# SP1 proof mode — mock | cpu | network
# mock:    instant fake proof, for testing only
# cpu:     real proof generated locally (slow, ~30 min)
# network: real proof via Succinct Prover Network
SP1_PROVER=cpu

# Required only when SP1_PROVER=network
# Get a key at https://docs.succinct.xyz/docs/network/developers/key-setup
NETWORK_PRIVATE_KEY=
