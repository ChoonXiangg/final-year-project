# Google Cloud Vision API Configuration
# Setup steps:
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the Cloud Vision API for your project
# 3. Create a Service Account (IAM > Service Accounts), assign role "Cloud Vision API User"
# 4. Download the JSON key and save it as ocr/credentials.json

# Path to your Google service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=

# Your Google Cloud project ID (found on the GCP Console dashboard)
GOOGLE_CLOUD_PROJECT_ID=

# Flask Configuration
FLASK_PORT=
FLASK_DEBUG=

# Sepolia RPC URL (for reading AppVerifier contract requirements)
SEPOLIA_RPC_URL=

# SP1 Prover mode: "mock" (fast, fake proof) | "cpu" (real proof, slow) | "network" (SP1 network)
SP1_PROVER=cpu

# Comma-separated list of allowed CORS origins (leave empty to block all browser cross-origin requests)
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=