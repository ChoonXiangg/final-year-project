# Path to your Google Cloud Vision service account key file
# Create one at https://console.cloud.google.com → IAM → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Flask server settings
FLASK_PORT=5001
FLASK_DEBUG=false

# Sepolia RPC URL for reading AppVerifier contract requirements
# Get one from Alchemy (https://alchemy.com) or Infura
SEPOLIA_RPC_URL=

# SP1 proof mode — mock | cpu | network
# mock:    instant fake proof, for testing only
# cpu:     real proof generated locally (slow, ~30 min)
# network: real proof via Succinct Prover Network
SP1_PROVER=cpu

# Comma-separated list of allowed CORS origins for browser clients
# Leave empty to block all cross-origin browser requests
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=
